---
# Self-hosted Renovate runner for Forgejo. Runs on a schedule (and on demand),
# reads renovate.json, and opens dependency-update PRs against this repo.
#
# To enable it:
#   1. Create a RENOVATE_TOKEN — a Forgejo access token (Settings >
#      Applications) with read/write on repositories and issues/PRs.
#   2. Save it as a repository (or organization) Actions secret named
#      RENOVATE_TOKEN: Settings > Actions > Secrets.
#   3. (Optional) adjust the schedule below; trigger manually from the Actions
#      tab via "Run workflow".
#
# RENOVATE_ENDPOINT is derived from the running instance, so this works on any
# self-hosted Forgejo — no hardcoded URL. The `forgejo` platform supersedes the
# deprecated `gitea` one; on an older renovate image, set RENOVATE_PLATFORM to
# `gitea` instead.
name: Renovate

on:
  schedule:
    - cron: "0 6 * * 1"
  workflow_dispatch: {}

jobs:
  renovate:
    runs-on: homelab
    container:
      image: renovate/renovate:latest
    steps:
      - name: Run Renovate
        env:
          RENOVATE_PLATFORM: forgejo
          RENOVATE_ENDPOINT: {% raw %}${{ github.server_url }}{% endraw %}/api/v1
          RENOVATE_TOKEN: {% raw %}${{ secrets.RENOVATE_TOKEN }}{% endraw %}
          RENOVATE_REPOSITORIES: {% raw %}${{ github.repository }}{% endraw %}
          RENOVATE_AUTODISCOVER: "false"
          LOG_LEVEL: info
        run: renovate
